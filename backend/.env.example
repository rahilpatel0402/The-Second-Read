# Copy this file to backend/.env and paste your Anthropic API key.
# Get a key from https://platform.claude.com/settings/.../keys  (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides (defaults to claude-opus-4-8).
# For a faster live demo you can use Sonnet 5:
# THESECONDREAD_MODEL=claude-sonnet-5
# THESECONDREAD_RETRIEVE_MODEL=claude-sonnet-5
